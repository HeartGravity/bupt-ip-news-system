{
    "name": "bupt-ip-news-system",
    "version": "1.0.0",
    "description": "北京邮电大学知识产权新闻系统",
    "main": "server/app.js",
    "scripts": {
        "start": "node server/app.js",
        "server": "nodemon server/app.js",
        "client": "cd client && npm start",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "build": "cd client && npm run build",
        "install-client": "cd client && npm install",
        "install-all": "npm install && npm run install-client",
        "seed": "node server/utils/seed.js",
        "seed-demo": "node server/utils/demo-seed.js",
        "crawl:news": "node server/utils/news-crawler.js",
        "import-law": "node server/utils/law-importer.js"
    },
    "dependencies": {
        "axios": "^1.8.1",
        "bcryptjs": "^2.4.3",
        "cheerio": "^1.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-validator": "^7.0.1",
        "iconv-lite": "^0.7.2",
        "jsonwebtoken": "^9.0.0",
        "mammoth": "^1.11.0",
        "mongoose": "^7.1.0",
        "morgan": "^1.10.0",
        "react-icons": "^5.5.0",
        "react-router-dom": "^7.3.0",
        "react-scripts": "^0.0.0",
        "rss-parser": "^3.13.0",
        "styled-components": "^6.1.15"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "nodemon": "^3.1.10"
    }
}
