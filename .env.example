# 服务器配置
PORT=5000
NODE_ENV=development # 可选值: development, production

# MongoDB数据库连接
MONGO_URI=mongodb://localhost:27017/bupt-ip-news

# JWT认证
JWT_SECRET=your_jwt_secret_key_here # 重要: 生产环境请使用强随机字符串
JWT_EXPIRE=30d

# CORS配置
CORS_ORIGIN=https://ip-news.bupt.edu.cn # 生产环境域名

# 图片上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880 # 5MB

# 其他配置
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=changeme # 初始管理员密码，请务必修改

# ── 智能助手配置 ─────────────────────────────────────────────────────────────
# 方式一：使用本地微调模型（优先级高于 Hunyuan API）
#   先启动推理服务器: python ml/inference/server.py --model ml/models/merged
#   然后取消注释以下两行：
# LOCAL_LLM_URL=http://localhost:8000
# LOCAL_LLM_MODEL=local-finetuned

# 方式二：使用腾讯混元外部 API（LOCAL_LLM_URL 未设置时生效）
# HUNYUAN_API_KEY=your_hunyuan_api_key_here

# 注意: 在生产环境中，确保使用安全的密钥和密码
# 不要将真实的.env文件提交到版本控制系统!